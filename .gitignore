# https://help.github.com/articles/ignoring-files/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE / tooling local ---
.idea/
*.swp
*.swo
*~

# --- Cursor / AI local (optional; remove if team commits these) ---
.cursor/
.claude/
.claude_code/

# --- Secrets & env (keep examples) ---
.env
.env.local
.env.*.local
**/.env
**/.env.local
!.env.example
!**/.env.example

# --- Database & Docker volumes (local) ---
postgres_data/
ms_postgres_data/
.db-data/
*.log

# --- Python (monorepo: any service / gateway) ---
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/.Python
**/venv/
**/.venv/
**/ENV/
**/env/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.egg-info/
**/dist/
**/.eggs/
**/.coverage
**/htmlcov/
**/.tox/

# --- Node / frontend (paths work from repo root) ---
node_modules/
**/node_modules/
frontend/.next/
frontend/out/
frontend/build/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Testing / coverage ---
coverage/
**/coverage/
.nyc_output/

# --- Next.js / misc frontend ---
.vercel
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- TypeScript ---
*.tsbuildinfo
